# Production-mode Vite build env. Vite inlines VITE_* at build time, so
# values land in the JS bundle. Points at the Hetzner prod hostnames
# (agripulse.cloud). The old AWS dev cluster (*.dev.agripulse.cloud) is
# being decommissioned; for a separate dev build, override these via
# --build-arg (the Dockerfile reads them via ARG fallthrough).

VITE_API_BASE_URL=https://api.agripulse.cloud/api

VITE_OIDC_AUTHORITY=https://keycloak.agripulse.cloud/realms/agripulse
VITE_OIDC_CLIENT_ID=agripulse-api
VITE_OIDC_REDIRECT_URI=https://app.agripulse.cloud/auth/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=https://app.agripulse.cloud/
VITE_OIDC_SCOPE=openid profile email
