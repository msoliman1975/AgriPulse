# Production-mode Vite build env. Vite inlines VITE_* at build time, so
# values land in the JS bundle. This file is hardcoded to the dev cluster
# hostnames until the deploy pipeline grows per-env image variants — for
# staging/prod, build with --build-arg overrides on these same keys
# (Dockerfile reads them via ARG fallthrough; see frontend/Dockerfile).

VITE_API_BASE_URL=https://api.dev.agripulse.cloud/api

VITE_OIDC_AUTHORITY=https://keycloak.dev.agripulse.cloud/realms/agripulse
VITE_OIDC_CLIENT_ID=agripulse-api
VITE_OIDC_REDIRECT_URI=https://app.dev.agripulse.cloud/auth/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=https://app.dev.agripulse.cloud/
VITE_OIDC_SCOPE=openid profile email
