# MissionAgre frontend — local development env example.
# Copy to frontend/.env.local and adjust as needed. All VITE_-prefixed
# vars are exposed to the browser at build time, so never put secrets here.

# --- API ------------------------------------------------------------------
# Backend reachable through Vite's dev proxy at /api (see vite.config.ts).
# In production builds, the absolute URL is injected at deploy time.
VITE_API_BASE_URL=/api

# --- Keycloak (OIDC) ------------------------------------------------------
# Matches infra/dev/compose.yaml realm 'missionagre' and client
# 'missionagre-api'. Production values come from the Keycloak prod realm.
VITE_OIDC_AUTHORITY=http://localhost:8080/realms/missionagre
VITE_OIDC_CLIENT_ID=missionagre-api
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/
VITE_OIDC_SCOPE=openid profile email
