# MissionAgre — local dev environment overrides.
#
# Copy to `infra/dev/.env` (gitignored) and fill in real values before
# starting any service that needs them. The compose stack reads only the
# variables a given service declares via `env_file:`; values not consumed
# are ignored. Do NOT commit real secrets to this file.

# --- Sentinel Hub ----------------------------------------------------------
# Wired into the API and worker pods in PR-B. Empty values cause
# `SentinelHubProvider` to raise `SentinelHubNotConfiguredError`, which
# the discovery Celery task catches and records as a failed job. That
# loud failure is intentional — we'd rather surface a misconfig than
# silently skip ingestion.
#
# Provision a Sentinel Hub OAuth client in the dashboard, then fill from
# 1Password / Bitwarden vault entry "missionagre/sentinel-hub-dev".
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# Defaults are the public Sentinel Hub deployment URLs; only override if
# pointing at a regional endpoint (e.g. services.sentinel-hub.com vs
# services-uswest2.sentinel-hub.com).
SENTINEL_HUB_OAUTH_URL=https://services.sentinel-hub.com/oauth/token
SENTINEL_HUB_CATALOG_URL=https://services.sentinel-hub.com/api/v1/catalog/1.0.0/search
SENTINEL_HUB_PROCESS_URL=https://services.sentinel-hub.com/api/v1/process

# --- Tile server -----------------------------------------------------------
# Frontend reads this from `GET /api/v1/config` so the SPA never hard-codes
# the URL. Local default points at the TiTiler container's host port.
TILE_SERVER_BASE_URL=http://localhost:8001
