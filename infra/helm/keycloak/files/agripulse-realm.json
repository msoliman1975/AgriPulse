{
  "realm": "agripulse",
  "displayName": "AgriPulse (dev)",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "loginTheme": "agripulse",
  "accountTheme": "agripulse",
  "roles": {
    "realm": [
      { "name": "PlatformAdmin", "description": "AgriPulse staff with full cross-tenant control." },
      { "name": "PlatformSupport", "description": "Read-only platform support access." },
      { "name": "TenantOwner", "description": "Tenant super-admin; exactly one per tenant." },
      { "name": "TenantAdmin", "description": "Tenant admin; all tenant capabilities except billing and ownership transfer." },
      { "name": "BillingAdmin", "description": "Subscription and billing only." },
      { "name": "Viewer", "description": "Read-only tenant access." }
    ]
  },
  "clients": [
    {
      "clientId": "agripulse-api",
      "name": "AgriPulse API (dev)",
      "description": "Single dev client. SPA flow for the frontend, ROPC for curl-driven backend testing. Audience mapper adds 'agripulse-api' to access tokens to match KEYCLOAK_AUDIENCE.",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:3000/*",
        "http://localhost:8000/*",
        "https://app.dev.agripulse.cloud/*",
        "https://api.dev.agripulse.cloud/*",
        "https://app.agripulse.cloud/*",
        "https://api.agripulse.cloud/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:3000",
        "http://localhost:8000",
        "https://app.dev.agripulse.cloud",
        "https://api.dev.agripulse.cloud",
        "https://app.agripulse.cloud",
        "https://api.agripulse.cloud"
      ],
      "attributes": {
        "post.logout.redirect.uris": "+",
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "audience-agripulse-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "agripulse-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "platform_role-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "platform_role",
            "claim.name": "platform_role",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false"
          }
        },
        {
          "name": "tenant_id-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenant_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false"
          }
        },
        {
          "name": "tenant_role-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant_role",
            "claim.name": "tenant_role",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false"
          }
        },
        {
          "name": "farm_scopes-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "farm_scopes",
            "claim.name": "farm_scopes",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "true"
          }
        }
      ]
    },
    {
      "clientId": "agripulse-tenancy",
      "name": "AgriPulse Tenancy (admin)",
      "description": "Service-account confidential client the api uses to provision Keycloak groups/users on tenant creation. Secret is set post-install by the promote Job; import only seeds the client shape.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "secret": "PLACEHOLDER_REPLACED_POST_INSTALL",
      "attributes": {
        "client.secret.creation.time": "0"
      }
    }
  ],
  "_comment_users": "Deployed clusters (helm) deliberately ship NO seed user — IH-1. The first PlatformAdmin is created by the PostSync promote job (promote-kc-admin.py) from KC_BOOTSTRAP_ADMIN_EMAIL + a temporary password sourced from a Secret, forcing UPDATE_PASSWORD on first login. The local docker-compose realm at infra/dev/keycloak/agripulse-realm.json keeps the dev/dev convenience user.",
  "users": []
}
