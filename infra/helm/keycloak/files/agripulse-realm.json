{
  "realm": "agripulse",
  "displayName": "AgriPulse (dev)",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "clients": [
    {
      "clientId": "agripulse-api",
      "name": "AgriPulse API (dev)",
      "description": "Single dev client. SPA flow for the frontend, ROPC for curl-driven backend testing. Audience mapper adds 'agripulse-api' to access tokens to match KEYCLOAK_AUDIENCE.",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:3000/*",
        "http://localhost:8000/*",
        "https://app.dev.agripulse.cloud/*",
        "https://api.dev.agripulse.cloud/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:3000",
        "http://localhost:8000",
        "https://app.dev.agripulse.cloud",
        "https://api.dev.agripulse.cloud"
      ],
      "attributes": {
        "post.logout.redirect.uris": "+",
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "audience-agripulse-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "agripulse-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "platform_role-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "platform_role",
            "claim.name": "platform_role",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false"
          }
        },
        {
          "name": "tenant_id-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenant_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false"
          }
        },
        {
          "name": "tenant_role-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant_role",
            "claim.name": "tenant_role",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false"
          }
        },
        {
          "name": "farm_scopes-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "farm_scopes",
            "claim.name": "farm_scopes",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "true"
          }
        }
      ]
    },
    {
      "clientId": "agripulse-tenancy",
      "name": "AgriPulse Tenancy (admin)",
      "description": "Service-account confidential client used by the api to provision Keycloak groups + users when a tenant is created. The secret is replaced post-install by a Job that reads agripulse/<env>/keycloak-client-secret from AWS Secrets Manager; realm import only seeds the client shape.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "secret": "PLACEHOLDER_REPLACED_POST_INSTALL",
      "attributes": {
        "client.secret.creation.time": "0"
      }
    }
  ],
  "users": [
    {
      "username": "dev@agripulse.local",
      "email": "dev@agripulse.local",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Dev",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "dev",
          "temporary": false
        }
      ]
    }
  ]
}
