# MissionAgre backend — local development env example.
# Copy to backend/.env and adjust.

# --- Service ---------------------------------------------------------------
APP_ENV=dev                     # dev | staging | production
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000
APP_METRICS_PORT=9090

# --- Database (CloudNativePG in cluster; local Postgres for dev) ----------
DATABASE_URL=postgresql+asyncpg://missionagre:missionagre@localhost:5432/missionagre
DATABASE_SYNC_URL=postgresql+psycopg://missionagre:missionagre@localhost:5432/missionagre
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# --- Redis (cache + Celery broker + SSE pub/sub) --------------------------
REDIS_URL=redis://localhost:6379/0

# --- Keycloak --------------------------------------------------------------
# Local: Keycloak from infra/dev/compose.yaml on http://localhost:8080.
# Realm pre-provisioned with client 'missionagre-api' and dev user
# 'dev@missionagre.local' (password 'dev'). Production issuer lives at
# https://keycloak.<env>.missionagre.io/realms/missionagre.
KEYCLOAK_ISSUER=http://localhost:8080/realms/missionagre
KEYCLOAK_AUDIENCE=missionagre-api
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/missionagre/protocol/openid-connect/certs
KEYCLOAK_JWKS_CACHE_TTL_SECONDS=3600

# --- Observability ---------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo.observability.svc.cluster.local:4318
OTEL_SERVICE_NAME=missionagre-api
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=dev

# --- Celery ----------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- CORS ------------------------------------------------------------------
# JSON-array form is required by pydantic-settings 2.6+: the dotenv source
# parses list[str] fields BEFORE field_validators run, so a comma-separated
# string fails before the `_split_csv` validator gets a chance.
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Object storage (MinIO in dev, S3 in prod) ----------------------------
# Endpoint URL is empty in prod (boto3 uses the AWS default endpoint); set
# to the MinIO container in dev. Bucket names are stable across envs and
# are pre-created by the minio-init sidecar in infra/dev/compose.yaml.
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=missionagre
S3_SECRET_ACCESS_KEY=missionagre-dev
S3_USE_PATH_STYLE=true
S3_BUCKET_IMAGERY=missionagre-imagery
S3_BUCKET_UPLOADS=missionagre-uploads
