# AgriPulse backend â€” local development env example.
# Copy to backend/.env and adjust.

# --- Service ---------------------------------------------------------------
APP_ENV=dev                     # dev | staging | production
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000
APP_METRICS_PORT=9090

# --- Database (CloudNativePG in cluster; local Postgres for dev) ----------
DATABASE_URL=postgresql+asyncpg://agripulse:agripulse@localhost:5432/agripulse
DATABASE_SYNC_URL=postgresql+psycopg://agripulse:agripulse@localhost:5432/agripulse
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# --- Redis (cache + Celery broker + SSE pub/sub) --------------------------
REDIS_URL=redis://localhost:6379/0

# --- Keycloak --------------------------------------------------------------
# Local: Keycloak from infra/dev/compose.yaml on http://localhost:8080.
# Realm pre-provisioned with client 'agripulse-api' and dev user
# 'dev@agripulse.local' (password 'dev'). Production issuer lives at
# https://keycloak.<env>.agripulse.cloud/realms/agripulse.
KEYCLOAK_ISSUER=http://localhost:8080/realms/agripulse
KEYCLOAK_AUDIENCE=agripulse-api
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/agripulse/protocol/openid-connect/certs
KEYCLOAK_JWKS_CACHE_TTL_SECONDS=3600

# --- Platform-admin bootstrap (PR-Reorg6) ---------------------------------
# On cold start, if no PlatformAdmin exists, the lifespan creates one with
# these values. Idempotent â€” subsequent boots are no-ops once an admin
# exists. Empty PLATFORM_ADMIN_EMAIL skips the bootstrap entirely.
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_FULL_NAME=Platform Admin

# --- Observability ---------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo.observability.svc.cluster.local:4318
OTEL_SERVICE_NAME=agripulse-api
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=dev

# --- Celery ----------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- CORS ------------------------------------------------------------------
# JSON-array form is required by pydantic-settings 2.6+: the dotenv source
# parses list[str] fields BEFORE field_validators run, so a comma-separated
# string fails before the `_split_csv` validator gets a chance.
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Sentinel Hub (imagery provider) --------------------------------------
# OAuth2 client-credentials. Create an OAuth client at
#   https://apps.sentinel-hub.com/dashboard/#/account/settings  (or via the
#   Planet "OAuth Clients" panel â€” they share an auth backend) and paste
#   the client_id / client_secret here. Tokens are minted from
#   /oauth/token (the realm-scoped /auth/realms/main/protocol/openid-connect/token
#   endpoint also works â€” both route to the same Keycloak instance).
# Empty values cause discover_scenes to record one synthetic failed
# ingestion job per refresh with error_message='sentinel_hub_not_configured'
# so the misconfig surfaces loudly in the UI rather than silently no-op'ing.
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# --- Object storage (MinIO in dev, S3 in prod) ----------------------------
# Endpoint URL is empty in prod (boto3 uses the AWS default endpoint); set
# to the MinIO container in dev. Bucket names are stable across envs and
# are pre-created by the minio-init sidecar in infra/dev/compose.yaml.
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=agripulse
S3_SECRET_ACCESS_KEY=agripulse-dev
S3_USE_PATH_STYLE=true
S3_BUCKET_IMAGERY=agripulse-imagery
S3_BUCKET_UPLOADS=agripulse-uploads

# --- SMTP (notifications email channel, PR-S4-D) --------------------------
# Local dev: MailHog from infra/dev/compose.yaml on localhost:1025; no
# auth, no TLS. Open http://localhost:8025 to read what got sent.
# Production: set host + STARTTLS + creds via ExternalSecret.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=false
SMTP_FROM=AgriPulse <noreply@agripulse.local>

# --- Webhook channel (PR-S4-E) --------------------------------------------
# In production the per-tenant signing secret is derived from a KMS key
# stored on `tenant_settings.webhook_signing_secret_kms_key`. Local dev
# has no KMS, so this fallback secret is used to sign payloads. Set to
# an empty string to disable dev signing (webhook channel will mark
# dispatches as 'skipped').
WEBHOOK_DEV_SECRET=dev-only-not-for-prod
