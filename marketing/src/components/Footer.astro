---
import Logo from "./Logo.astro";
const year = new Date().getFullYear();
---
<footer class="border-t border-sand-300 bg-white">
  <div class="container-pad grid gap-10 py-14 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
    <div>
      <Logo />
      <p class="mt-4 max-w-sm text-sm text-muted">
        The always-on agronomist for every farm.
      </p>
      <p class="mt-3 text-xs text-muted-soft">
        Built for orchards in the MENA region. Arabic and English, by design.
      </p>
    </div>
    <div>
      <p class="eyebrow">Capabilities</p>
      <ul class="mt-4 space-y-2 text-sm text-muted">
        <li><a href="/capabilities#crop-health-monitoring" class="hover:text-leaf-700">Crop health monitoring</a></li>
        <li><a href="/capabilities#built-in-health-indices" class="hover:text-leaf-700">Built-in health indices</a></li>
        <li><a href="/capabilities#farm-planning" class="hover:text-leaf-700">Farm planning</a></li>
        <li><a href="/capabilities#intelligent-recommendations" class="hover:text-leaf-700">Intelligent recommendations</a></li>
        <li><a href="/capabilities#proactive-alerting" class="hover:text-leaf-700">Proactive alerting</a></li>
        <li><a href="/capabilities#custom-signals" class="hover:text-leaf-700">Custom signals</a></li>
        <li><a href="/capabilities#bilingual" class="hover:text-leaf-700">Bilingual</a></li>
      </ul>
    </div>
    <div>
      <p class="eyebrow">Explore</p>
      <ul class="mt-4 space-y-2 text-sm text-muted">
        <li><a href="/customers" class="hover:text-leaf-700">Customers</a></li>
        <li><a href="/where-we-operate" class="hover:text-leaf-700">Where we operate</a></li>
        <li><a href="/contact" class="hover:text-leaf-700">Contact</a></li>
        <li><a href="/contact#demo" class="hover:text-leaf-700">Request a demo</a></li>
      </ul>
    </div>
    <div>
      <p class="eyebrow">Contact</p>
      <ul class="mt-4 space-y-2 text-sm text-muted">
        <li><a href="mailto:platform@agripulse.tech" class="hover:text-leaf-700">platform@agripulse.tech</a></li>
        <li class="text-muted-soft">Cairo · Egypt</li>
      </ul>
    </div>
  </div>
  <div class="border-t border-sand-300/80">
    <div class="container-pad flex flex-col items-start justify-between gap-2 py-5 text-xs text-muted md:flex-row md:items-center">
      <p>© {year} AgriPulse. All rights reserved.</p>
      <p>See it before the canopy shows it.</p>
    </div>
  </div>
</footer>
